{
  "name": "@foundry/core",
  "version": "0.1.0",
  "description": "HSL color formula engine with WCAG contrast checking and semantic token generation",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./css": "./dist/tokens.css"
  },
  "scripts": {
    "build": "tsc && node scripts/build.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "format": "prettier --check src",
    "format:fix": "prettier --write src"
  },
  "devDependencies": {
    "typescript": "^5.4.0",
    "vitest": "^1.6.0",
    "prettier": "^3.2.0",
    "eslint": "^9.0.0"
  }
}